# ─────────────────────────────────────────────────────────────────────────────
# Stash — environment.  Copy to .env.local and fill what you have.
# EVERYTHING is optional: with nothing set, the pre-seeded Demo shop and the whole
# UI still work; the live "upload your own pile" path activates the moment a key
# exists. No secret is ever hardcoded or committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── The brain (Qwen Cloud — the intended provider) ───────────────────────────
# Get a key at https://dashscope-intl.console.aliyun.com  (a plain sk- key).
# Setting this routes identify / appraise / compose / negotiate to Qwen Cloud.
DASHSCOPE_API_KEY=
# Base URL is the eligibility-gated Qwen Cloud endpoint (leave as default).
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Model ids (defaults match the design; override if your account exposes other ids).
QWEN_VL_MODEL=qwen3-vl-plus
QWEN_TEXT_MODEL=qwen3.7-plus
QWEN_HAGGLE_MODEL=qwen3.7-max
QWEN_EMBED_MODEL=text-embedding-v4

# ── Dev / verification fallback provider (optional) ──────────────────────────
# If DASHSCOPE_API_KEY is empty but this is set, the SAME real pipeline runs via
# Anthropic's OpenAI-compatible endpoint, so the flow is verifiable end-to-end.
# Qwen always wins when both are present.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Force a provider explicitly: qwen | anthropic | none  (default: auto-detect)
STASH_AI_PROVIDER=

# ── Live comparable listings (eBay Browse API) ───────────────────────────────
# Free app keys at https://developer.ebay.com. Client-credentials -> Browse API.
# Without these, the appraiser reasons without live comps and says so honestly.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_US
# Sandbox vs production Browse host: api.sandbox.ebay.com | api.ebay.com
EBAY_ENV=production

# ── Real one-tap eBay publish (opt-in bonus; the seller's OWN account) ────────
# A seller User OAuth access token with the Sell Inventory scope. Optional.
EBAY_OAUTH_TOKEN=

# ── Storage ──────────────────────────────────────────────────────────────────
# Where shops, items, the append-only ledger, scrubbed photos and generated
# catalogue-plates live. Defaults to ./.data (persists on any host with a disk;
# on ephemeral serverless it resets — deploy on a VM/Docker for durability).
STASH_DATA_DIR=

# Public base URL used only for building shareable links in copy (never for fetches).
# Leave empty to derive from the incoming request.
NEXT_PUBLIC_STASH_BASE_URL=
